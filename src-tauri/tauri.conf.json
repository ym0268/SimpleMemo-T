{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "simplememo-t",
  "version": "0.1.0",
  "identifier": "io.github.ym0268.simplememo-t",
  "build": {
    "frontendDist": "../src",
    "removeUnusedCommands": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SimpleMemo",
        "width": 250,
        "height": 250,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": "'none'",
        "style-src": "'self'",
        "script-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
    
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "wix": {
        "language": "ja-JP"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
